# ══════════════════════════════════════════════════════════════════
#  FlightTrack v3 — Environment Variables
#  Add these in Vercel: Settings → Environment Variables
# ══════════════════════════════════════════════════════════════════

# ── REQUIRED ──────────────────────────────────────────────────────
# Powers Claude AI agent with live web search (Google Flights, Kayak, Skyscanner)
# Get from: console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── OPTIONAL: Add any/all for better real-time pricing ────────────

# SerpAPI — Google Flights data (BEST real-time prices)
# Sign up: https://serpapi.com → Dashboard → API Key
# Free: 100 searches/month | Paid: $50/mo for 5,000
SERPAPI_KEY=your_serpapi_key_here

# Kiwi Tequila — Budget airlines & cheapest combinations
# Sign up: https://tequila.kiwi.com → Solutions → Create account
# Free tier available, no credit card required
KIWI_API_KEY=your_kiwi_api_key_here

# Duffel — NDC live bookable fares (300+ airlines)
# Sign up: https://app.duffel.com/join → free test account
# Test mode: unlimited, Production: contact Duffel
DUFFEL_ACCESS_TOKEN=duffel_test_your_token_here

# Aviationstack — Route & airline discovery
# Sign up: https://aviationstack.com → Get Free API Key
# Free: 100 requests/month
AVIATIONSTACK_KEY=your_aviationstack_key_here

# ── OPTIONAL: Email alerts ────────────────────────────────────────
# Resend — sends email when price alert fires
# Sign up: https://resend.com → API Keys → Create Key
# Free: 100 emails/day, no credit card
RESEND_API_KEY=re_your_key_here
ALERT_FROM_EMAIL=FlightTrack <onboarding@resend.dev>

# ── REQUIRED ─────────────────────────────────────────────────────────────────
# Powers the Claude AI agent with real web search across all booking sites
# Get from: console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── OPTIONAL: Duffel API (best Amadeus alternative — real live fares) ─────────
# Sign up FREE at: app.duffel.com/join (no credit card needed for test mode)
# Gives 300+ airlines, real bookable fares, no fixed airline list
# If not set, falls back to Claude web search
DUFFEL_ACCESS_TOKEN=duffel_test_your_token_here

# ── OPTIONAL: Email alerts via Resend ─────────────────────────────────────────
# Sign up FREE at: resend.com (100 emails/day free, no credit card)
# Sends email when any price alert threshold is hit
RESEND_API_KEY=re_your_key_here
ALERT_FROM_EMAIL=FlightTrack <onboarding@resend.dev>

# ══════════════════════════════════════════════════════════════════
#  FlightTrack v3 — Environment Variables
#  Add in Vercel: Settings → Environment Variables → Redeploy
# ══════════════════════════════════════════════════════════════════

# ── PRIMARY APIs (add both for best results) ──────────────────────

# SerpAPI — Google Flights real-time data (best price accuracy)
# Sign up free: https://serpapi.com → Dashboard → API Key
# Free: 100 searches/month
SERPAPI_KEY=your_serpapi_key_here

# Duffel — NDC airline fares (often cheaper than GDS prices)
# Sign up free: https://app.duffel.com/join → Developers → Access tokens
# Free test mode, no credit card
DUFFEL_ACCESS_TOKEN=duffel_test_your_token_here

# ── FALLBACK ONLY (optional — only used if SerpAPI + Duffel not set) ──

# Anthropic — Claude AI agent with web search
# Only activates when NO other flight APIs are configured
# If you have SerpAPI + Duffel, you do NOT need this key
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── EMAIL ALERTS (optional) ───────────────────────────────────────

# Resend — sends email when price drops below your alert threshold
# Sign up free: https://resend.com → API Keys (100 emails/day free)
RESEND_API_KEY=re_your_key_here
ALERT_FROM_EMAIL=FlightTrack <onboarding@resend.dev>
